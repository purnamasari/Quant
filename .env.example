# Optional Quant AI provider overrides.
# Quant runs without these variables. The Settings tab is the preferred setup
# path and also supports encrypted OpenAI, Gemini, Grok, and Claude API keys.

# Enable model calls and select the local llama.cpp provider.
QUANT_LLM_ENABLED=1
QUANT_LLM_PROVIDER=local

# OpenAI-compatible server base URL. The server should expose:
#   GET  /health
#   POST /v1/chat/completions
QUANT_LLM_BASE_URL=http://127.0.0.1:8080/v1

# Model name sent to /v1/chat/completions.
QUANT_LLM_MODEL=gemma-4-e4b-it
